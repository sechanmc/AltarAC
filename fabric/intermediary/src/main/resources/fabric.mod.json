{
  "schemaVersion": 1,
  "id": "AltarAC-fabric-intermediary",
  "version": "${version}",
  "name": "AltarAC",
  "description": "Libre simulation anticheat designed for 26.1 with 1.8-26.1 support, powered by PacketEvents 2.0.",
  "authors": [
    "AltarAC"
  ],
  "license": "GPLv3",
  "environment": "server",
  "entrypoints": {
    "main": [
      "ac.altarac.platform.fabric.AltarACFabricIntermediaryEntryPoint"
    ],
    "preLaunch": [
      "ac.altarac.platform.fabric.AltarACFabricIntermediaryEntryPoint"
    ]
  },
  "mixins": [
    "AltarAC.mixins.json"
  ],
  "accessWidener": "AltarAC.accesswidener",
  "custom": {
    "loom:injected_interfaces": {
      "net/minecraft/world/level/Level": [
        "ac/altarac/platform/api/world/PlatformWorld"
      ],
      "net/minecraft/world/entity/Entity": [
        "ac/altarac/platform/fabric/inject/FabricEntityHandle"
      ],
      "net/minecraft/server/level/ServerPlayer": [
        "ac/altarac/platform/fabric/inject/FabricServerPlayerHandle"
      ],
      "net/minecraft/server/MinecraftServer": [
        "ac/altarac/platform/fabric/inject/FabricMinecraftServerHandle"
      ],
      "net/minecraft/commands/CommandSourceStack": [
        "ac/altarac/platform/api/sender/Sender"
      ]
    }
  },
  "depends": {
    "minecraft": "\u003e\u003d1.16.1 \u003c26",
    "java": "\u003e\u003d17",
    "fabricloader": "\u003e\u003d0.16",
    "fabric-lifecycle-events-v1": "*",
    "packetevents": "*"
  },
  "recommends": {
    "cloud": "*",
    "fabric-permissions-api-v0": "*",
    "luckperms": "*"
  }
}
